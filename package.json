{
  "name": "scottlab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kmehltretter82/scottlab.git"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@scottlab/web",
    "build": "npm run typecheck && npm run build --workspace=@scottlab/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "oxlint --react-plugin --vitest-plugin --jsx-a11y-plugin --deny-warnings .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "preview": "npm run preview --workspace=@scottlab/web"
  },
  "devDependencies": {
    "oxlint": "^1.73.0"
  }
}
