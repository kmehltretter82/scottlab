{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:scottlab:schema:approximable-mapping:1",
  "title": "ScottLab Approximable Mapping v1",
  "description": "A finite set of generator rules for an approximable mapping between two ScottLab information systems.",
  "$comment": "Shape validation is necessary but not sufficient. ScottLab must also validate system references, token references, and the approximable-mapping laws.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "title",
    "description",
    "approximation",
    "sourceSystemId",
    "targetSystemId",
    "rules"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "kind": {
      "const": "approximable-mapping"
    },
    "id": {
      "$ref": "#/$defs/identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "approximation": {
      "oneOf": [
        {
          "$ref": "#/$defs/exactRepresentation"
        },
        {
          "$ref": "#/$defs/boundedRepresentation"
        }
      ]
    },
    "sourceSystemId": {
      "$ref": "#/$defs/identifier"
    },
    "targetSystemId": {
      "$ref": "#/$defs/identifier"
    },
    "rules": {
      "type": "array",
      "uniqueItems": true,
      "description": "Finite input-observation generators for output tokens.",
      "items": {
        "$ref": "#/$defs/generatorRule"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "tokenId": {
      "$ref": "#/$defs/identifier"
    },
    "tokenSet": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/tokenId"
      }
    },
    "generatorRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "premises",
        "conclusion"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "premises": {
          "$ref": "#/$defs/tokenSet"
        },
        "conclusion": {
          "$ref": "#/$defs/tokenId"
        }
      }
    },
    "exactRepresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "exact"
        }
      }
    },
    "boundedRepresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "bound"
      ],
      "properties": {
        "kind": {
          "const": "bounded"
        },
        "bound": {
          "type": "string",
          "minLength": 1,
          "description": "A visible, human-readable bound on this finite approximation."
        }
      }
    }
  }
}
